<script
  src="{{ 'countdown-timer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<countdown-timer
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
  data-end-date="{{ section.settings.end_date }}"
  data-layout="{{ section.settings.layout }}"
>
  <div class="countdown-timer__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="countdown-timer__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="countdown-timer__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="countdown-timer__grid countdown-timer__grid--{{ section.settings.layout }}" ref="timerGrid">
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="days">00</span>
        <span class="countdown-timer__label">Days</span>
      </div>
      <span class="countdown-timer__separator">:</span>
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="hours">00</span>
        <span class="countdown-timer__label">Hours</span>
      </div>
      <span class="countdown-timer__separator">:</span>
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="minutes">00</span>
        <span class="countdown-timer__label">Minutes</span>
      </div>
      <span class="countdown-timer__separator">:</span>
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="seconds">00</span>
        <span class="countdown-timer__label">Seconds</span>
      </div>
    </div>

    <div class="countdown-timer__expired" ref="expiredMessage" hidden>
      <p>{{ section.settings.expired_message }}</p>
    </div>

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link }}"
        class="countdown-timer__button"
        ref="ctaButton"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</countdown-timer>

{% stylesheet %}
  countdown-timer {
    display: block;
    width: 100%;
    text-align: center;
  }

  .countdown-timer__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .countdown-timer__heading {
    font-size: var(--font-size--h2, 2rem);
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .countdown-timer__subheading {
    font-size: var(--font-size--body, 1rem);
    margin: 0 0 32px;
    opacity: 0.7;
    line-height: 1.5;
  }

  .countdown-timer__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .countdown-timer__grid--stacked {
    flex-direction: column;
    gap: 12px;
  }

  .countdown-timer__grid--stacked .countdown-timer__separator {
    display: none;
  }

  .countdown-timer__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    min-width: 80px;
    background: var(--color-foreground);
    color: var(--color-background);
    border-radius: 12px;
    padding: 20px 16px;
  }

  .countdown-timer__grid--stacked .countdown-timer__unit {
    flex-direction: row;
    justify-content: center;
    gap: 12px;
    width: 100%;
    max-width: 300px;
    padding: 16px 24px;
  }

  .countdown-timer__value {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .countdown-timer__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.8;
  }

  .countdown-timer__separator {
    font-size: 2rem;
    font-weight: 700;
    opacity: 0.4;
  }

  .countdown-timer__expired p {
    font-size: var(--font-size--h3, 1.25rem);
    opacity: 0.7;
    margin: 0;
  }

  .countdown-timer__button {
    display: inline-block;
    margin-top: 32px;
    padding: 14px 32px;
    background: var(--color-foreground);
    color: var(--color-background);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: opacity 0.2s ease;
  }

  .countdown-timer__button:hover {
    opacity: 0.85;
  }

  @media (max-width: 600px) {
    .countdown-timer__grid--inline {
      gap: 8px;
    }

    .countdown-timer__unit {
      min-width: 64px;
      padding: 16px 8px;
    }

    .countdown-timer__value {
      font-size: 1.75rem;
    }

    .countdown-timer__separator {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Countdown timer",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [],
  "settings": [
    {
      "type": "text",
      "id": "end_date",
      "label": "End date (YYYY-MM-DDTHH:MM)",
      "default": "2026-12-31T23:59",
      "info": "Format: YYYY-MM-DDTHH:MM (e.g. 2026-12-31T23:59)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sale Ends In"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Don't miss out on our biggest sale of the year"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "expired_message",
      "label": "Expired message",
      "default": "This offer has ended."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "inline",
          "label": "Inline"
        },
        {
          "value": "stacked",
          "label": "Stacked"
        }
      ],
      "default": "inline"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Countdown timer",
      "category": "Premium"
    }
  ]
}
{% endschema %}
