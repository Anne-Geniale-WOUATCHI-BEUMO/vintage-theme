<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="artisan-testimonials__container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="artisan-testimonials__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="artisan-testimonials__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="artisan-testimonials__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="artisan-testimonials__grid artisan-testimonials__grid--{{ section.settings.layout }}">
        {%- for block in section.blocks -%}
          {%- comment -%} Alternate rotation angles per card {%- endcomment -%}
          {%- assign rotation_index = forloop.index0 | modulo: 4 -%}
          {%- case rotation_index -%}
            {%- when 0 -%}{%- assign rotation_class = 'rot-neg2' -%}
            {%- when 1 -%}{%- assign rotation_class = 'rot-pos1' -%}
            {%- when 2 -%}{%- assign rotation_class = 'rot-pos3' -%}
            {%- when 3 -%}{%- assign rotation_class = 'rot-neg1' -%}
          {%- endcase -%}

          <div
            class="artisan-testimonials__card artisan-testimonials__card--{{ rotation_class }}"
            {{ block.shopify_attributes }}
          >
            {%- comment -%} Decorative open-quote {%- endcomment -%}
            <div class="artisan-testimonials__quote-mark" aria-hidden="true">&ldquo;</div>

            {%- comment -%} Quote text {%- endcomment -%}
            {%- if block.settings.quote != blank -%}
              <div class="artisan-testimonials__quote">
                {{ block.settings.quote }}
              </div>
            {%- endif -%}

            {%- comment -%} Star rating {%- endcomment -%}
            {%- if block.settings.rating != blank and block.settings.rating != '0' -%}
              <div class="artisan-testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                {%- assign rating_num = block.settings.rating | plus: 0 -%}
                {%- for i in (1..5) -%}
                  {%- if i <= rating_num -%}
                    <svg class="artisan-testimonials__star artisan-testimonials__star--filled" width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="currentColor" stroke="currentColor" stroke-width="1"/>
                    </svg>
                  {%- else -%}
                    <svg class="artisan-testimonials__star artisan-testimonials__star--empty" width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="none" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- comment -%} Author info {%- endcomment -%}
            <div class="artisan-testimonials__author">
              {%- if block.settings.image != blank -%}
                <div class="artisan-testimonials__avatar">
                  <img
                    src="{{ block.settings.image | image_url: width: 96 }}"
                    alt="{{ block.settings.author | escape }}"
                    width="48"
                    height="48"
                    loading="lazy"
                    class="artisan-testimonials__avatar-img"
                  >
                </div>
              {%- endif -%}

              <div class="artisan-testimonials__author-info">
                {%- if block.settings.author != blank -%}
                  <span class="artisan-testimonials__name">{{ block.settings.author }}</span>
                {%- endif -%}

                {%- if block.settings.location != blank -%}
                  <span class="artisan-testimonials__location">{{ block.settings.location }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .artisan-testimonials__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .artisan-testimonials__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .artisan-testimonials__heading {
    font-size: var(--font-size--h2, 2rem);
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .artisan-testimonials__subheading {
    font-size: var(--font-size--body, 1rem);
    margin: 0;
    opacity: 0.7;
    line-height: 1.5;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ---- Grid layout ---- */
  .artisan-testimonials__grid--grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    align-items: start;
  }

  /* ---- Carousel / horizontal scroll layout ---- */
  .artisan-testimonials__grid--carousel {
    display: flex;
    gap: 32px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }

  .artisan-testimonials__grid--carousel .artisan-testimonials__card {
    flex: 0 0 320px;
    scroll-snap-align: start;
  }

  /* ---- Card (polaroid style) ---- */
  .artisan-testimonials__card {
    background: inherit;
    border: 1px solid rgba(0, 0, 0, 0.08);
    padding: 32px 28px 28px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    position: relative;
    transition: box-shadow 0.2s ease;

    /* Thick white polaroid-style bottom */
    border-bottom-width: 6px;
  }

  /* Rotation classes */
  .artisan-testimonials__card--rot-neg2 { transform: rotate(-2deg); }
  .artisan-testimonials__card--rot-pos1 { transform: rotate(1deg); }
  .artisan-testimonials__card--rot-pos3 { transform: rotate(3deg); }
  .artisan-testimonials__card--rot-neg1 { transform: rotate(-1deg); }

  .artisan-testimonials__card:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.1), 0 2px 6px rgba(0, 0, 0, 0.05);
  }

  /* ---- Decorative open quote ---- */
  .artisan-testimonials__quote-mark {
    font-size: 4rem;
    line-height: 1;
    font-family: Georgia, 'Times New Roman', serif;
    opacity: 0.15;
    position: absolute;
    top: 8px;
    left: 20px;
    user-select: none;
  }

  /* ---- Quote text ---- */
  .artisan-testimonials__quote {
    font-size: 0.9375rem;
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 16px;
  }

  .artisan-testimonials__quote p {
    margin: 0 0 8px;
  }

  .artisan-testimonials__quote p:last-child {
    margin-bottom: 0;
  }

  /* ---- Star rating ---- */
  .artisan-testimonials__stars {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
  }

  .artisan-testimonials__star--filled {
    color: #d4a017;
  }

  .artisan-testimonials__star--empty {
    opacity: 0.25;
  }

  /* ---- Author ---- */
  .artisan-testimonials__author {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: 16px;
  }

  .artisan-testimonials__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid rgba(0, 0, 0, 0.06);
  }

  .artisan-testimonials__avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .artisan-testimonials__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .artisan-testimonials__name {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .artisan-testimonials__location {
    font-size: 0.8125rem;
    opacity: 0.55;
    line-height: 1.3;
  }

  /* ---- Responsive ---- */
  @media (max-width: 992px) {
    .artisan-testimonials__grid--grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .artisan-testimonials__grid--grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    /* Remove rotation on mobile */
    .artisan-testimonials__card--rot-neg2,
    .artisan-testimonials__card--rot-pos1,
    .artisan-testimonials__card--rot-pos3,
    .artisan-testimonials__card--rot-neg1 {
      transform: none;
    }

    .artisan-testimonials__grid--carousel .artisan-testimonials__card {
      flex: 0 0 280px;
    }

    /* Remove rotation in carousel on mobile too */
    .artisan-testimonials__grid--carousel .artisan-testimonials__card--rot-neg2,
    .artisan-testimonials__grid--carousel .artisan-testimonials__card--rot-pos1,
    .artisan-testimonials__grid--carousel .artisan-testimonials__card--rot-pos3,
    .artisan-testimonials__grid--carousel .artisan-testimonials__card--rot-neg1 {
      transform: none;
    }

    .artisan-testimonials__header {
      margin-bottom: 32px;
    }
  }

  /* Hide scrollbar on carousel but keep functionality */
  .artisan-testimonials__grid--carousel::-webkit-scrollbar {
    height: 4px;
  }

  .artisan-testimonials__grid--carousel::-webkit-scrollbar-track {
    background: transparent;
  }

  .artisan-testimonials__grid--carousel::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 2px;
  }
{% endstylesheet %}

