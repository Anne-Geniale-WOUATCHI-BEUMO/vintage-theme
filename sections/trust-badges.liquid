<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="trust-badges__container trust-badges__container--{{ section.settings.layout }}">
    {%- for block in section.blocks -%}
      <div class="trust-badges__item" {{ block.shopify_attributes }}>
        <div class="trust-badges__icon trust-badges__icon--{{ section.settings.icon_size }}">
          {%- case block.settings.icon -%}
            {%- when 'shipping' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 16V3H1v13h15z"/>
                <path d="M16 8h4l3 3v5h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            {%- when 'guarantee' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            {%- when 'secure' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
                <circle cx="12" cy="16" r="1"/>
              </svg>
            {%- when 'support' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            {%- when 'quality' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
          {%- endcase -%}
        </div>

        {%- if block.settings.title != blank -%}
          <h3 class="trust-badges__title">{{ block.settings.title }}</h3>
        {%- endif -%}

        {%- if block.settings.description != blank -%}
          <p class="trust-badges__description">{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .trust-badges__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .trust-badges__container--horizontal {
    display: flex;
    align-items: flex-start;
    justify-content: space-evenly;
    gap: 24px;
  }

  .trust-badges__container--grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 32px;
  }

  .trust-badges__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }

  .trust-badges__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trust-badges__icon svg {
    width: 100%;
    height: 100%;
  }

  .trust-badges__icon--small {
    width: 28px;
    height: 28px;
  }

  .trust-badges__icon--medium {
    width: 40px;
    height: 40px;
  }

  .trust-badges__icon--large {
    width: 56px;
    height: 56px;
  }

  .trust-badges__title {
    font-size: var(--font-size--body, 1rem);
    font-weight: 600;
    margin: 4px 0 0;
    line-height: 1.3;
  }

  .trust-badges__description {
    font-size: 0.875rem;
    margin: 0;
    opacity: 0.7;
    line-height: 1.4;
    max-width: 220px;
  }

  @media (max-width: 768px) {
    .trust-badges__container--horizontal {
      flex-wrap: wrap;
      justify-content: center;
    }

    .trust-badges__item {
      flex: 0 0 calc(50% - 12px);
    }
  }

  @media (max-width: 480px) {
    .trust-badges__container--horizontal .trust-badges__item {
      flex: 0 0 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust badges",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "shipping",
              "label": "Shipping"
            },
            {
              "value": "guarantee",
              "label": "Guarantee"
            },
            {
              "value": "secure",
              "label": "Secure"
            },
            {
              "value": "support",
              "label": "Support"
            },
            {
              "value": "quality",
              "label": "Quality"
            }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On all orders over $50"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "select",
      "id": "icon_size",
      "label": "Icon size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "category": "Premium",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "description": "On all orders over $50"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "guarantee",
            "title": "Money-Back Guarantee",
            "description": "30-day return policy"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "secure",
            "title": "Secure Checkout",
            "description": "SSL encrypted payments"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "support",
            "title": "24/7 Support",
            "description": "We're here to help"
          }
        }
      ]
    }
  ]
}
{% endschema %}
