<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="craftsmanship-steps__container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="craftsmanship-steps__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="craftsmanship-steps__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="craftsmanship-steps__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="craftsmanship-steps__track craftsmanship-steps__track--{{ section.settings.layout }} craftsmanship-steps__line--{{ section.settings.line_style }}">
        {%- for block in section.blocks -%}
          <div class="craftsmanship-steps__step" {{ block.shopify_attributes }}>
            {%- comment -%} Connector line between steps (before badge) {%- endcomment -%}
            {%- if forloop.first == false -%}
              <div class="craftsmanship-steps__connector" aria-hidden="true"></div>
            {%- endif -%}

            <div class="craftsmanship-steps__badge" aria-hidden="true">
              <span class="craftsmanship-steps__number">{{ forloop.index }}</span>
            </div>

            {%- if block.settings.image != blank -%}
              <div class="craftsmanship-steps__image-wrap">
                <img
                  src="{{ block.settings.image | image_url: width: 480 }}"
                  alt="{{ block.settings.title | escape }}"
                  width="480"
                  height="{{ 480 | divided_by: block.settings.image.aspect_ratio | round }}"
                  loading="lazy"
                  class="craftsmanship-steps__image"
                >
              </div>
            {%- endif -%}

            <div class="craftsmanship-steps__content">
              {%- if block.settings.title != blank -%}
                <h3 class="craftsmanship-steps__title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="craftsmanship-steps__description">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .craftsmanship-steps__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .craftsmanship-steps__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .craftsmanship-steps__heading {
    font-size: var(--font-size--h2, 2rem);
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .craftsmanship-steps__subheading {
    font-size: var(--font-size--body, 1rem);
    margin: 0;
    opacity: 0.7;
    line-height: 1.5;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ---- Horizontal layout ---- */
  .craftsmanship-steps__track--horizontal {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
  }

  .craftsmanship-steps__track--horizontal .craftsmanship-steps__step {
    flex: 1;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }

  /* Horizontal connector line */
  .craftsmanship-steps__track--horizontal .craftsmanship-steps__connector {
    position: absolute;
    top: 22px;
    right: calc(50% + 28px);
    width: calc(100% - 56px);
    height: 0;
    border-top-width: 2px;
    border-top-color: currentColor;
    opacity: 0.3;
  }

  .craftsmanship-steps__track--horizontal.craftsmanship-steps__line--solid .craftsmanship-steps__connector {
    border-top-style: solid;
  }

  .craftsmanship-steps__track--horizontal.craftsmanship-steps__line--dotted .craftsmanship-steps__connector {
    border-top-style: dotted;
  }

  .craftsmanship-steps__track--horizontal.craftsmanship-steps__line--dashed .craftsmanship-steps__connector {
    border-top-style: dashed;
  }

  /* ---- Vertical layout ---- */
  .craftsmanship-steps__track--vertical {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    max-width: 720px;
    margin: 0 auto;
  }

  .craftsmanship-steps__track--vertical .craftsmanship-steps__step {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 24px;
    position: relative;
    padding-bottom: 40px;
  }

  .craftsmanship-steps__track--vertical .craftsmanship-steps__step:last-child {
    padding-bottom: 0;
  }

  .craftsmanship-steps__track--vertical .craftsmanship-steps__badge {
    grid-row: 1 / -1;
    grid-column: 1;
    align-self: start;
  }

  .craftsmanship-steps__track--vertical .craftsmanship-steps__image-wrap {
    grid-column: 2;
  }

  .craftsmanship-steps__track--vertical .craftsmanship-steps__content {
    grid-column: 2;
  }

  /* Vertical connector line */
  .craftsmanship-steps__track--vertical .craftsmanship-steps__connector {
    position: absolute;
    left: 21px;
    bottom: calc(100% - 4px);
    height: 40px;
    width: 0;
    border-left-width: 2px;
    border-left-color: currentColor;
    opacity: 0.3;
  }

  .craftsmanship-steps__track--vertical.craftsmanship-steps__line--solid .craftsmanship-steps__connector {
    border-left-style: solid;
  }

  .craftsmanship-steps__track--vertical.craftsmanship-steps__line--dotted .craftsmanship-steps__connector {
    border-left-style: dotted;
  }

  .craftsmanship-steps__track--vertical.craftsmanship-steps__line--dashed .craftsmanship-steps__connector {
    border-left-style: dashed;
  }

  /* ---- Badge ---- */
  .craftsmanship-steps__badge {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    background: inherit;
  }

  .craftsmanship-steps__number {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1;
  }

  /* ---- Image ---- */
  .craftsmanship-steps__image-wrap {
    width: 100%;
    margin: 16px 0 12px;
    border-radius: 8px;
    overflow: hidden;
  }

  .craftsmanship-steps__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* ---- Content ---- */
  .craftsmanship-steps__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .craftsmanship-steps__description {
    font-size: 0.9375rem;
    margin: 0;
    opacity: 0.7;
    line-height: 1.5;
  }

  /* ---- Responsive: always vertical on mobile ---- */
  @media (max-width: 768px) {
    .craftsmanship-steps__track--horizontal {
      flex-direction: column;
      align-items: flex-start;
      max-width: 720px;
      margin: 0 auto;
    }

    .craftsmanship-steps__track--horizontal .craftsmanship-steps__step {
      max-width: none;
      width: 100%;
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      column-gap: 24px;
      text-align: left;
      padding-bottom: 40px;
      position: relative;
    }

    .craftsmanship-steps__track--horizontal .craftsmanship-steps__step:last-child {
      padding-bottom: 0;
    }

    .craftsmanship-steps__track--horizontal .craftsmanship-steps__badge {
      grid-row: 1 / -1;
      grid-column: 1;
      align-self: start;
    }

    .craftsmanship-steps__track--horizontal .craftsmanship-steps__image-wrap {
      grid-column: 2;
    }

    .craftsmanship-steps__track--horizontal .craftsmanship-steps__content {
      grid-column: 2;
    }

    /* Switch horizontal connector from top to left */
    .craftsmanship-steps__track--horizontal .craftsmanship-steps__connector {
      top: auto;
      right: auto;
      width: 0;
      height: 40px;
      left: 21px;
      bottom: calc(100% - 4px);
      border-top: none;
    }

    .craftsmanship-steps__track--horizontal.craftsmanship-steps__line--solid .craftsmanship-steps__connector {
      border-left-style: solid;
      border-left-width: 2px;
      border-left-color: currentColor;
      border-top-style: none;
    }

    .craftsmanship-steps__track--horizontal.craftsmanship-steps__line--dotted .craftsmanship-steps__connector {
      border-left-style: dotted;
      border-left-width: 2px;
      border-left-color: currentColor;
      border-top-style: none;
    }

    .craftsmanship-steps__track--horizontal.craftsmanship-steps__line--dashed .craftsmanship-steps__connector {
      border-left-style: dashed;
      border-left-width: 2px;
      border-left-color: currentColor;
      border-top-style: none;
    }

    .craftsmanship-steps__header {
      margin-bottom: 40px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Craftsmanship steps",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Describe this step of the process."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It's Made"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every piece is crafted with care through our time-honored process."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "select",
      "id": "line_style",
      "label": "Connecting line style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        }
      ],
      "default": "dotted"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Craftsmanship steps",
      "category": "Premium",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Source Materials",
            "description": "We carefully select the finest raw materials from trusted local suppliers."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Hand Cut & Shape",
            "description": "Each piece is hand-cut and shaped by our skilled artisans."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Assemble & Stitch",
            "description": "Components are assembled and stitched using traditional techniques."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Quality Inspection",
            "description": "Every finished product undergoes rigorous quality checks before shipping."
          }
        }
      ]
    }
  ]
}
{% endschema %}
