<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section spacing-style color-{{ section.settings.color_scheme }}"
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="heritage-banner__container">
    <div class="heritage-banner__frame heritage-banner__frame--{{ section.settings.ornament_style }}">
      {%- comment -%} Background image layer {%- endcomment -%}
      {%- if section.settings.background_image != blank -%}
        <div class="heritage-banner__bg-image">
          <img
            src="{{ section.settings.background_image | image_url: width: 1920 }}"
            alt=""
            width="1920"
            height="{{ 1920 | divided_by: section.settings.background_image.aspect_ratio | round }}"
            loading="lazy"
            class="heritage-banner__bg-img"
          >
        </div>
      {%- endif -%}

      {%- comment -%} Grain texture overlay {%- endcomment -%}
      <div class="heritage-banner__grain" aria-hidden="true"></div>

      {%- comment -%} Corner ornaments {%- endcomment -%}
      <div class="heritage-banner__corner heritage-banner__corner--tl" aria-hidden="true"></div>
      <div class="heritage-banner__corner heritage-banner__corner--tr" aria-hidden="true"></div>
      <div class="heritage-banner__corner heritage-banner__corner--bl" aria-hidden="true"></div>
      <div class="heritage-banner__corner heritage-banner__corner--br" aria-hidden="true"></div>

      {%- comment -%} Established badge {%- endcomment -%}
      {%- if section.settings.established_year != blank -%}
        <div class="heritage-banner__badge">
          <span class="heritage-banner__badge-label">Est.</span>
          <span class="heritage-banner__badge-year">{{ section.settings.established_year }}</span>
        </div>
      {%- endif -%}

      {%- comment -%} Content {%- endcomment -%}
      <div class="heritage-banner__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="heritage-banner__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="heritage-banner__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .heritage-banner__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .heritage-banner__frame {
    position: relative;
    overflow: hidden;
    padding: 80px 60px;
    text-align: center;

    /* Double border: inner border + outer outline */
    border: 2px solid currentColor;
    outline: 3px solid currentColor;
    outline-offset: 6px;
  }

  /* ---- Background image ---- */
  .heritage-banner__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .heritage-banner__bg-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
  }

  /* ---- Grain texture overlay (CSS noise) ---- */
  .heritage-banner__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.08;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
  }

  /* ---- Corner ornaments ---- */
  .heritage-banner__corner {
    position: absolute;
    width: 32px;
    height: 32px;
    z-index: 2;
  }

  .heritage-banner__corner--tl { top: 14px; left: 14px; }
  .heritage-banner__corner--tr { top: 14px; right: 14px; }
  .heritage-banner__corner--bl { bottom: 14px; left: 14px; }
  .heritage-banner__corner--br { bottom: 14px; right: 14px; }

  /* Simple ornament: L-shaped corners */
  .heritage-banner__frame--simple .heritage-banner__corner::before,
  .heritage-banner__frame--simple .heritage-banner__corner::after {
    content: '';
    position: absolute;
    background: currentColor;
    opacity: 0.6;
  }

  .heritage-banner__frame--simple .heritage-banner__corner::before {
    width: 100%;
    height: 2px;
  }

  .heritage-banner__frame--simple .heritage-banner__corner::after {
    width: 2px;
    height: 100%;
  }

  /* Position L-corners correctly */
  .heritage-banner__frame--simple .heritage-banner__corner--tl::before { top: 0; left: 0; }
  .heritage-banner__frame--simple .heritage-banner__corner--tl::after  { top: 0; left: 0; }

  .heritage-banner__frame--simple .heritage-banner__corner--tr::before { top: 0; right: 0; }
  .heritage-banner__frame--simple .heritage-banner__corner--tr::after  { top: 0; right: 0; }

  .heritage-banner__frame--simple .heritage-banner__corner--bl::before { bottom: 0; left: 0; }
  .heritage-banner__frame--simple .heritage-banner__corner--bl::after  { bottom: 0; left: 0; }

  .heritage-banner__frame--simple .heritage-banner__corner--br::before { bottom: 0; right: 0; }
  .heritage-banner__frame--simple .heritage-banner__corner--br::after  { bottom: 0; right: 0; }

  /* Floral ornament: decorative diamond + lines */
  .heritage-banner__frame--floral .heritage-banner__corner::before {
    content: '';
    position: absolute;
    width: 10px;
    height: 10px;
    border: 2px solid currentColor;
    opacity: 0.6;
    transform: rotate(45deg);
  }

  .heritage-banner__frame--floral .heritage-banner__corner::after {
    content: '';
    position: absolute;
    border-style: solid;
    border-color: currentColor;
    opacity: 0.4;
  }

  .heritage-banner__frame--floral .heritage-banner__corner--tl::before { top: -2px; left: -2px; }
  .heritage-banner__frame--floral .heritage-banner__corner--tl::after  { top: 0; left: 0; width: 24px; height: 24px; border-width: 1px 0 0 1px; }

  .heritage-banner__frame--floral .heritage-banner__corner--tr::before { top: -2px; right: -2px; }
  .heritage-banner__frame--floral .heritage-banner__corner--tr::after  { top: 0; right: 0; width: 24px; height: 24px; border-width: 1px 1px 0 0; }

  .heritage-banner__frame--floral .heritage-banner__corner--bl::before { bottom: -2px; left: -2px; }
  .heritage-banner__frame--floral .heritage-banner__corner--bl::after  { bottom: 0; left: 0; width: 24px; height: 24px; border-width: 0 0 1px 1px; }

  .heritage-banner__frame--floral .heritage-banner__corner--br::before { bottom: -2px; right: -2px; }
  .heritage-banner__frame--floral .heritage-banner__corner--br::after  { bottom: 0; right: 0; width: 24px; height: 24px; border-width: 0 1px 1px 0; }

  /* ---- Established badge ---- */
  .heritage-banner__badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 2px solid currentColor;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 3;
    background: inherit;
  }

  .heritage-banner__badge-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    line-height: 1;
    opacity: 0.7;
  }

  .heritage-banner__badge-year {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.2;
  }

  /* ---- Content ---- */
  .heritage-banner__content {
    position: relative;
    z-index: 2;
    margin-top: 24px;
  }

  .heritage-banner__heading {
    font-size: var(--font-size--h1, 2.5rem);
    font-family: var(--font-heading-family, Georgia, 'Times New Roman', serif);
    font-weight: 400;
    margin: 0 0 12px;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .heritage-banner__subheading {
    font-size: var(--font-size--body, 1rem);
    margin: 0;
    opacity: 0.7;
    line-height: 1.6;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    font-style: italic;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .heritage-banner__frame {
      padding: 56px 24px;
      outline-offset: 4px;
    }

    .heritage-banner__badge {
      width: 64px;
      height: 64px;
    }

    .heritage-banner__badge-label {
      font-size: 0.5625rem;
    }

    .heritage-banner__badge-year {
      font-size: 1rem;
    }

    .heritage-banner__heading {
      font-size: 1.75rem;
    }

    .heritage-banner__corner {
      width: 24px;
      height: 24px;
    }

    .heritage-banner__frame--floral .heritage-banner__corner--tl::after,
    .heritage-banner__frame--floral .heritage-banner__corner--tr::after,
    .heritage-banner__frame--floral .heritage-banner__corner--bl::after,
    .heritage-banner__frame--floral .heritage-banner__corner--br::after {
      width: 18px;
      height: 18px;
    }

    .heritage-banner__content {
      margin-top: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Heritage banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Timeless Craftsmanship"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Proudly handmade with passion and tradition, one piece at a time."
    },
    {
      "type": "text",
      "id": "established_year",
      "label": "Established year",
      "default": "1920"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "ornament_style",
      "label": "Corner ornament style",
      "options": [
        {
          "value": "simple",
          "label": "Simple"
        },
        {
          "value": "floral",
          "label": "Floral"
        }
      ],
      "default": "simple"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Heritage banner",
      "category": "Premium"
    }
  ]
}
{% endschema %}
