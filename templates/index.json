    "artisan_testimonials_1": {
      "type": "artisan-testimonials",
      "blocks": {
        "testimonial_1": {
          "type": "testimonial",
          "settings": {
            "quote": "<p>I bought the leather tote three years ago and it only looks better with age. The patina is gorgeous. This is the kind of bag you pass down.</p>",
            "author": "Margaret H.",
            "location": "Savannah, GA",
            "rating": "5"
          }
        },
        "testimonial_2": {
          "type": "testimonial",
          "settings": {
            "quote": "<p>The candles smell exactly like walking through a forest after rain. Nothing artificial, nothing overwhelming. Just honest, beautiful scent.</p>",
            "author": "Daniel K.",
            "location": "Burlington, VT",
            "rating": "5"
          }
        },
        "testimonial_3": {
          "type": "testimonial",
          "settings": {
            "quote": "<p>I ordered the soap gift set for my mother and she called me in tears. The packaging, the scent, the little handwritten note — every detail was perfect.</p>",
            "author": "Clara J.",
            "location": "Asheville, NC",
            "rating": "5"
          }
        }
      },
      "block_order": [
        "testimonial_1",
        "testimonial_2",
        "testimonial_3"
      ],
      "settings": {
        "heading": "From Our Community",
        "subheading": "Honest words from the people who live with our handmade goods every day.",
        "layout": "grid",
