    "faq_section_1": {
      "type": "faq-section",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "Are your products really handmade?",
            "answer": "<p>Yes, every single item is made by hand in our Vermont workshop. We use no factory production lines. Each piece is crafted by a skilled artisan from start to finish, which is why slight variations between pieces are normal and celebrated.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "What materials do you use?",
            "answer": "<p>We use vegetable-tanned leather sourced from Tuscany, 100% soy wax and beeswax for our candles, organic essential oils for our soaps, and sustainably harvested wood for our home goods. We never use synthetic fragrances, petroleum-based waxes, or chrome-tanned leather.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "How long will shipping take?",
            "answer": "<p>Because each item is made to order, please allow 5-10 business days for production. Shipping within the US takes an additional 3-5 business days. International orders typically arrive within 10-18 business days.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Can I return or exchange my order?",
